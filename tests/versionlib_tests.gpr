with "config/versionlib_tests_config.gpr";
with "project_tools.gpr";
project Versionlib_Tests is

   for Source_Dirs use ("src/", "config/");
   for Object_Dir use "obj/" & Versionlib_Tests_Config.Build_Profile;
   for Create_Missing_Dirs use "True";
   for Exec_Dir use "bin";
   for Main use ("tests.adb");

   package Compiler is
      for Default_Switches ("Ada") use Versionlib_Tests_Config.Ada_Compiler_Switches &
        ("-gnat2022", "-gnatyM120", "-gnatX", "-gnata");
   end Compiler;

   package Binder is
      for Switches ("Ada") use ("-Es"); --  Symbolic traceback
   end Binder;

   package Linker is
      for Default_Switches ("Ada") use ("-lssl", "-lcrypto");
   end Linker;

   package Install is
      for Artifacts (".") use ("share");
   end Install;

end Versionlib_Tests;
